# dependencies
node_modules/

# build outputs
dist/
dist-ssr/
build/
*.local

# spellcheck dictionary — copiado de node_modules/dictionary-pt em
# postinstall. Nao versionar pra nao inflar o repo (.aff+.dic ~= 5MB).
public/dict/

# Tauri build artifacts
src-tauri/target/
src-tauri/gen/schemas/

# Tauri signing keys — NUNCA committar
# A chave privada de assinatura do updater fica em ~/.tauri/ por
# convencao, mas se algum *.key parar dentro do repo por engano, esse
# glob bloqueia. Perda dela = canal de update morto pra todos os users
# que ja' instalaram (a publica ta compilada nos binaries).
*.key
.tauri/
src-tauri/.tauri/

# editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# env
.env
.env.*
!.env.example

.claude/
.claude*/
CLAUDE.md
Claude.md
claude.md
CLAUDE*.md
Claude*.md
claude*.md

CHANGELOG.md
CHANGES.md

.gitignore